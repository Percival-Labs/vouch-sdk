{
  "name": "@percival-labs/vouch-sdk",
  "version": "0.2.3",
  "description": "Verifiable trust for AI agents — register, verify, and prove trust in 4 lines of code",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "vouch-sdk": "dist/cli.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc --noCheck",
    "prepublishOnly": "tsc --noCheck",
    "serve": "bun run src/cli.ts serve",
    "keygen": "bun run src/cli.ts keygen",
    "test": "bun test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Percival-Labs/vouch-sdk.git"
  },
  "homepage": "https://github.com/Percival-Labs/vouch-sdk",
  "bugs": {
    "url": "https://github.com/Percival-Labs/vouch-sdk/issues"
  },
  "keywords": [
    "ai-agents",
    "trust",
    "nostr",
    "vouch",
    "reputation",
    "mcp",
    "lightning",
    "sdk",
    "typescript"
  ],
  "dependencies": {
    "@noble/curves": "^1.8.2",
    "@scure/base": "^1.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "bun-types": "^1.3.10",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
